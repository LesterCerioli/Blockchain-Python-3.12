# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
POSTGRES_DB=fastchainbank
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DB_TIMEZONE="UTC"

# Ethereum service
# Local development: postgresql+asyncpg://<user>:<password>@localhost:5432/<db>
# Production (Render): set this to the managed database URL provided by the host
ETH_DATABASE_URL=postgresql+asyncpg://postgres:change_me@localhost:5432/fastchainbank
ETH_STALE_BLOCK_THRESHOLD_SECONDS=60

# Ethereum RPC provider
# Local development: http://localhost:8545 (Geth --dev, chain-id 1337)
# Inside Docker:     http://eth-node:8545
# Production: replace with an external RPC endpoint (Infura, Alchemy, QuickNode)
ETH_PROVIDERS=[{"name":"primary","url":"http://localhost:8545","priority":1,"request_timeout":10.0,"circuit_breaker_failure_threshold":5,"circuit_breaker_recovery_seconds":60}]

# ---------------------------------------------------------------------------
# Bitcoin RPC configuration
# Local development: bitcoind running in regtest mode (--profile local-chain)
# Inside Docker:     http://bitcoind:18443
# Production: replace with an external Bitcoin node or service (e.g. Blockstream)
# ---------------------------------------------------------------------------
BTC_RPC_USER=bitcoin
BTC_RPC_PASSWORD=change_me
BTC_RPC_URL=http://localhost:18443
BTC_RPC_WALLET=

# ---------------------------------------------------------------------------
# DeFi service (DEFI_ prefix)
# All fields are optional — the service starts with these defaults if unset.
# ---------------------------------------------------------------------------

# Database
# Local development: postgresql+asyncpg://<user>:<password>@localhost:5432/cryptobank
# Production: set this to the managed database URL provided by the host
DEFI_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/cryptobank

# Cache (Redis)
# DEFI_REDIS_URL  — generic cache (DB 0)
# DEFI_CACHE_URL  — dedicated cache for market data (DB 1)
DEFI_REDIS_URL=redis://localhost:6379/0
DEFI_CACHE_URL=redis://localhost:6379/1

# TTL configuration (seconds)
DEFI_QUOTE_CACHE_TTL_SECONDS=30
DEFI_HISTORY_CACHE_TTL_SECONDS=300
DEFI_PRICE_CACHE_TTL_SECONDS=30

# Market data provider
# Base URL for the CoinGecko v3 REST API used for price feeds
DEFI_PRICE_ORACLE_URL=https://api.coingecko.com/api/v3

# Timeouts and batch limits
DEFI_MARKET_DATA_TIMEOUT_SECONDS=10
DEFI_MARKET_DATA_REFRESH_INTERVAL_SECONDS=60
DEFI_MAX_SYMBOLS_PER_BATCH=100

# Indexer
# Block number from which on-chain event indexing starts (0 = chain genesis)
DEFI_INDEXER_START_BLOCK=0

# Trading — slippage tolerance in basis points (1 bps = 0.01%)
DEFI_DEFAULT_SLIPPAGE_BPS=50
DEFI_MAX_SLIPPAGE_BPS=500

# Feature flags
DEFI_COMPLIANCE_SCREENING_ENABLED=false
DEFI_AUDIT_LOG_ENABLED=true

# Supported chains
# Comma-separated list of chain IDs the platform accepts
# Default: Ethereum (1), Polygon (137), Arbitrum One (42161)
DEFI_SUPPORTED_CHAIN_IDS=[1,137,42161]

# ---------------------------------------------------------------------------
# Multi-chain RPC configuration (FEATURE 1.3.2)
# Override individual RPC URLs at deploy time — never commit real keys.
# Each entry corresponds to a chain in DeFiSettings.chains.
# The full chains dict can also be overridden as JSON via DEFI_CHAINS.
# ---------------------------------------------------------------------------
# DEFI_CHAINS={"1":{"name":"Ethereum","rpc_url":"https://mainnet.infura.io/v3/YOUR_KEY","explorer":"https://etherscan.io","is_testnet":false},...}

# ---------------------------------------------------------------------------
# Secret API keys — DO NOT set real values here.
# Inject at deploy time via secrets manager (Vault, AWS Secrets Manager, etc.)
# or via CI/CD secret injection. Never commit real keys to source control.
# ---------------------------------------------------------------------------
# DEFI_COINGECKO_API_KEY=
# DEFI_CMC_API_KEY=
# DEFI_OFAC_API_KEY=
