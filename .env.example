# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
POSTGRES_DB=fastchainbank
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Ethereum service
# Local development: postgresql+asyncpg://<user>:<password>@localhost:5432/<db>
# Production (Render): set this to the managed database URL provided by the host
ETH_DATABASE_URL=postgresql+asyncpg://postgres:change_me@localhost:5432/fastchainbank
ETH_STALE_BLOCK_THRESHOLD_SECONDS=60

# Ethereum RPC provider
# Local development: http://localhost:8545 (Hardhat or Anvil)
# Production: replace with an external RPC endpoint (Infura, Alchemy, QuickNode)
ETH_PROVIDERS=[{"name":"primary","url":"http://localhost:8545","priority":1,"request_timeout":10.0,"circuit_breaker_failure_threshold":5,"circuit_breaker_recovery_seconds":60}]
